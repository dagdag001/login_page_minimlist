# PostgreSQL — required. Create DB + user, then set URL:
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/DATABASE_NAME

# JWT signing secret — required in production (16+ characters). For local dev,
# if unset, the server uses a built-in dev-only secret and prints a warning.
JWT_SECRET=change-this-to-a-long-random-secret
# Optional token lifetime (default 7d)
# JWT_EXPIRES_IN=7d

# Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID (Web)
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com

# Rate limiting (in-memory; per server process). Optional overrides:
# RATE_LIMIT_API_WINDOW_MS=60000
# RATE_LIMIT_API_MAX=120
# RATE_LIMIT_AUTH_WINDOW_MS=900000
# RATE_LIMIT_AUTH_MAX=30
# Behind a reverse proxy, set so req.ip uses X-Forwarded-For:
# TRUST_PROXY=1
